{
  "crons": [
    {
      "path": "/api/process-email-schedules",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/view-file/(.*)", "destination": "/api/view-file?path=$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
