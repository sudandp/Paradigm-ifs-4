# Paradigm Office 4 - Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — ONLY used server-side (never prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Google GenAI (for document extraction features) ---
VITE_API_KEY=your-google-genai-api-key

# --- Firebase (for push notifications) ---
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- Google OAuth ---
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Internal API (optional) ---
INTERNAL_API_KEY=your-internal-api-key

# --- SMTP (set via Supabase settings table, or override here for local dev) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
