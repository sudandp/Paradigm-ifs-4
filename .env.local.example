# Paradigm Office 4 - Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — ONLY used server-side (never prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Google GenAI (for document extraction features) ---
VITE_API_KEY=your-google-genai-api-key

# --- Firebase (for push notifications) ---
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- Google OAuth ---
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Internal API (optional) ---
INTERNAL_API_KEY=your-internal-api-key

# --- SMTP (set via Supabase settings table, or override here for local dev) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ─────────────────────────────────────────────────────────────────────────────
# BLUE-GUARD-2026 — KYC Gateway Configuration
# Set VITE_KYC_VENDOR to ONE of: hyperverge | signzy | decentro
# Only the active vendor's keys are used; the others are ignored.
# ─────────────────────────────────────────────────────────────────────────────
VITE_KYC_VENDOR=hyperverge

# --- HyperVerge (https://docs.hyperverge.co) ---
VITE_KYC_HYPERVERGE_APP_ID=your-hyperverge-app-id
VITE_KYC_HYPERVERGE_APP_KEY=your-hyperverge-app-key

# --- Signzy (https://docs.signzy.com) ---
VITE_KYC_SIGNZY_API_KEY=your-signzy-api-key
VITE_KYC_SIGNZY_PATIENT_ID=your-signzy-patient-id

# --- Decentro (https://docs.decentro.tech) ---
VITE_KYC_DECENTRO_CLIENT_ID=your-decentro-client-id
VITE_KYC_DECENTRO_CLIENT_SECRET=your-decentro-client-secret
VITE_KYC_DECENTRO_MODULE_SECRET=your-decentro-module-secret
VITE_KYC_DECENTRO_PROVIDER_SECRET=your-decentro-provider-secret

# ─────────────────────────────────────────────────────────────────────────────
# BLUE-GUARD-2026 — e-Sign Gateway Configuration
# Set VITE_ESIGN_VENDOR to ONE of: digio | leegality | signdesk
# ─────────────────────────────────────────────────────────────────────────────
VITE_ESIGN_VENDOR=digio

# --- Digio (https://app.digio.in) ---
VITE_ESIGN_DIGIO_CLIENT_ID=your-digio-client-id
VITE_ESIGN_DIGIO_CLIENT_SECRET=your-digio-client-secret

# --- Leegality (https://docs.leegality.com) ---
VITE_ESIGN_LEEGALITY_AUTH_TOKEN=your-leegality-auth-token

# --- SignDesk (https://docs.sign-desk.com) ---
VITE_ESIGN_SIGNDESK_APP_ID=your-signdesk-app-id
VITE_ESIGN_SIGNDESK_API_KEY=your-signdesk-api-key

# ─────────────────────────────────────────────────────────────────────────────
# BLUE-GUARD-2026 — Document Hosting
# ─────────────────────────────────────────────────────────────────────────────
# URL of the standard Paradigm employment agreement PDF hosted in Supabase Storage
VITE_EMPLOYMENT_AGREEMENT_PDF_URL=https://your-project.supabase.co/storage/v1/object/public/contracts/paradigm_employment_agreement_v1.pdf
